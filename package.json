{
  "name": "ringconf-v2.1",
  "version": "2.7.5",
  "scripts": {
    "start": "ng serve --host 127.0.0.1 --port 4200 --proxy-config proxy.conf.json",
    "start & open": "ng serve --host 127.0.0.1 --port 4200 --open",
    "build": "ng build",
    "build:development": "ng build --configuration development",
    "build:production": "ng build --configuration production",
    "build:woocommerce": "ng build --configuration woocommerce",
    "build:deploy": "npm run build:deploy:release",
    "build:deploy:release": "ng build --configuration production --base-href ./ && node tools/build-deploy-package.mjs --channel releases",
    "build:deploy:development": "ng build --configuration development --base-href ./ && node tools/build-deploy-package.mjs --channel development",
    "deploy:sftp": "npm run deploy:release",
    "deploy:release": "node tools/deploy-sftp.mjs --channel releases",
    "deploy:development": "node tools/deploy-sftp.mjs --channel development",
    "deploy:staging": "npm run build:deploy:development && npm run deploy:development",
    "deploy:dry-run": "npm run deploy:dry-run:release",
    "deploy:dry-run:release": "node tools/deploy-sftp.mjs --dry-run --channel releases",
    "deploy:dry-run:development": "node tools/deploy-sftp.mjs --dry-run --channel development",
    "buildWoocommerce": "ng build --configuration=woocommerce && node postbuild.woocommerce.js",
    "check:admin-exclusion": "node tools/check-admin-exclusion.mjs"
  },
  "private": true,
  "engines": {
    "node": ">=24.15.0 <25",
    "npm": ">=11 <12"
  },
  "dependencies": {
    "@angular/animations": "^22.0.5",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/platform-browser": "^22.0.5",
    "@angular/platform-browser-dynamic": "^22.0.5",
    "@angular/router": "^22.0.5",
    "@babylonjs/core": "9.15.0",
    "@babylonjs/inspector": "9.15.0",
    "@babylonjs/loaders": "9.15.0",
    "@babylonjs/materials": "9.15.0",
    "@babylonjs/serializers": "9.15.0",
    "pepjs": "^0.5.3",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "~22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@types/jasmine": "~4.3.0",
    "browserslist": "^4.28.4",
    "browserslist-useragent-regexp": "^4.1.4",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~4.5.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "ssh2-sftp-client": "^12.1.1",
    "typescript": "~6.0.3"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "@fortawesome/fontawesome-common-types@6.2.1": true,
    "@fortawesome/fontawesome-svg-core@6.2.1": true,
    "@fortawesome/free-regular-svg-icons@6.2.1": true,
    "@fortawesome/free-solid-svg-icons@6.2.1": true,
    "@parcel/watcher@2.5.6": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true
  }
}
